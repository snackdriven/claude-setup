{
  "version": "1",
  "components": {
    "better-buddy": {
      "repo": "https://github.com/snackdriven/better-buddy.git",
      "installer": "scripts/install.sh",
      "description": "Virtual companion buddy + buddy-status.sh shim",
      "provides": ["~/.claude/commands/buddy.md", "~/.claude/buddy-status.sh", "~/.claude/buddy-hook.sh", "~/.claude/buddy-stop.sh"]
    },
    "claude-statusline": {
      "repo": "https://github.com/snackdriven/claude-statusline.git",
      "installer": "install.sh",
      "description": "Multi-region statusline renderer + all producers",
      "provides": ["~/.claude/buddy/", "~/.claude/settings.json#statusLine"]
    },
    "scratch-pad": {
      "repo": "https://github.com/snackdriven/scratch-pad.git",
      "installer": "scripts/sync-claude.sh",
      "description": "Operator vault, side brain map, config sync",
      "provides": ["~/.claude/operator/", "~/.claude/SIDE_BRAIN_MAP.md"]
    },
    "operator-core-mini": {
      "repo": "https://github.com/snackdriven/operator-core-mini.git",
      "description": "Three-layer memory system (Backpack/Doctrine/Hoard) — no installer; clone-only for now",
      "provides": ["~/.memory-keeper/"]
    }
  },
  "profiles": {
    "companion": {
      "components": ["better-buddy", "claude-statusline"],
      "description": "Buddy + statusline only"
    },
    "qa": {
      "components": ["better-buddy", "claude-statusline", "scratch-pad"],
      "description": "QA workflow setup (no memory system)"
    },
    "full": {
      "components": ["better-buddy", "claude-statusline", "scratch-pad", "operator-core-mini"],
      "description": "Everything"
    }
  },
  "env": {
    "QA_BRAIN_URL": {
      "default": "http://localhost:3737",
      "description": "qa-brain API base URL"
    },
    "QA_SHOW_RELEASE_OPS": {
      "default": "0",
      "description": "Show upcoming release in statusline (1/0)"
    },
    "QA_STATE_CACHE_SECONDS": {
      "default": "15",
      "description": "Cache window for qa_state producer"
    }
  }
}
